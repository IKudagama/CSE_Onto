<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE rdf:RDF [
    <!ENTITY owl "http://www.w3.org/2002/07/owl#" >
    <!ENTITY xsd "http://www.w3.org/2001/XMLSchema#" >
    <!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#" >
    <!ENTITY rdf "http://www.w3.org/1999/02/22-rdf-syntax-ns#" >
    <!ENTITY smi "http://www.semanticweb.org/ontologies/StockMarketInvestment#" >
]>

<rdf:RDF xmlns="http://www.semanticweb.org/ontologies/StockMarketInvestment#"
     xml:base="http://www.semanticweb.org/ontologies/StockMarketInvestment"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:smi="http://www.semanticweb.org/ontologies/StockMarketInvestment#">

    <!-- ============================================================ -->
    <!--  Ontology Declaration                                         -->
    <!-- ============================================================ -->

    <owl:Ontology rdf:about="http://www.semanticweb.org/ontologies/StockMarketInvestment">
        <rdfs:label xml:lang="en">Stock Market Investment and Risk Classification Ontology</rdfs:label>
        <rdfs:comment xml:lang="en">
            An ontology modelling stocks, investors, portfolios, market sectors,
            risk classifications, and investment strategies for the purpose of
            answering competency questions about stock market investments.
        </rdfs:comment>
        <owl:versionInfo>1.0</owl:versionInfo>
    </owl:Ontology>

    <!-- ============================================================ -->
    <!--  CLASS HIERARCHY                                              -->
    <!-- ============================================================ -->

    <!-- Top-level: FinancialInstrument -->
    <owl:Class rdf:about="smi:FinancialInstrument">
        <rdfs:label>Financial Instrument</rdfs:label>
        <rdfs:comment>Any tradable asset in the financial market.</rdfs:comment>
    </owl:Class>

    <!-- Stock -->
    <owl:Class rdf:about="smi:Stock">
        <rdfs:subClassOf rdf:resource="smi:FinancialInstrument"/>
        <rdfs:label>Stock</rdfs:label>
        <rdfs:comment>A share of ownership in a publicly listed company.</rdfs:comment>
    </owl:Class>

    <!-- GrowthStock -->
    <owl:Class rdf:about="smi:GrowthStock">
        <rdfs:subClassOf rdf:resource="smi:Stock"/>
        <rdfs:label>Growth Stock</rdfs:label>
        <rdfs:comment>A stock expected to grow at an above-average rate compared to the market.</rdfs:comment>
    </owl:Class>

    <!-- ValueStock -->
    <owl:Class rdf:about="smi:ValueStock">
        <rdfs:subClassOf rdf:resource="smi:Stock"/>
        <rdfs:label>Value Stock</rdfs:label>
        <rdfs:comment>A stock trading below its intrinsic or book value.</rdfs:comment>
    </owl:Class>

    <!-- DividendStock -->
    <owl:Class rdf:about="smi:DividendStock">
        <rdfs:subClassOf rdf:resource="smi:Stock"/>
        <rdfs:label>Dividend Stock</rdfs:label>
        <rdfs:comment>A stock that pays regular dividends to shareholders.</rdfs:comment>
    </owl:Class>

    <!-- PennyStock -->
    <owl:Class rdf:about="smi:PennyStock">
        <rdfs:subClassOf rdf:resource="smi:Stock"/>
        <rdfs:label>Penny Stock</rdfs:label>
        <rdfs:comment>A highly speculative stock trading at very low prices.</rdfs:comment>
    </owl:Class>

    <!-- Bond -->
    <owl:Class rdf:about="smi:Bond">
        <rdfs:subClassOf rdf:resource="smi:FinancialInstrument"/>
        <rdfs:label>Bond</rdfs:label>
        <rdfs:comment>A fixed-income debt instrument issued by a corporation or government.</rdfs:comment>
    </owl:Class>

    <!-- ETF -->
    <owl:Class rdf:about="smi:ETF">
        <rdfs:subClassOf rdf:resource="smi:FinancialInstrument"/>
        <rdfs:label>ETF</rdfs:label>
        <rdfs:comment>Exchange-Traded Fund tracking an index, sector, or asset class.</rdfs:comment>
    </owl:Class>

    <!-- Company -->
    <owl:Class rdf:about="smi:Company">
        <rdfs:label>Company</rdfs:label>
        <rdfs:comment>A publicly listed corporation that issues stocks.</rdfs:comment>
    </owl:Class>

    <!-- MarketSector -->
    <owl:Class rdf:about="smi:MarketSector">
        <rdfs:label>Market Sector</rdfs:label>
        <rdfs:comment>A segment of the economy grouping companies with similar business activities.</rdfs:comment>
    </owl:Class>

    <!-- Sector sub-classes -->
    <owl:Class rdf:about="smi:TechnologySector">
        <rdfs:subClassOf rdf:resource="smi:MarketSector"/>
        <rdfs:label>Technology Sector</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="smi:HealthcareSector">
        <rdfs:subClassOf rdf:resource="smi:MarketSector"/>
        <rdfs:label>Healthcare Sector</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="smi:EnergySector">
        <rdfs:subClassOf rdf:resource="smi:MarketSector"/>
        <rdfs:label>Energy Sector</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="smi:FinancialSector">
        <rdfs:subClassOf rdf:resource="smi:MarketSector"/>
        <rdfs:label>Financial Sector</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="smi:ConsumerGoodsSector">
        <rdfs:subClassOf rdf:resource="smi:MarketSector"/>
        <rdfs:label>Consumer Goods Sector</rdfs:label>
    </owl:Class>

    <!-- RiskLevel -->
    <owl:Class rdf:about="smi:RiskLevel">
        <rdfs:label>Risk Level</rdfs:label>
        <rdfs:comment>A classification of investment risk.</rdfs:comment>
    </owl:Class>
    <owl:Class rdf:about="smi:LowRisk">
        <rdfs:subClassOf rdf:resource="smi:RiskLevel"/>
        <rdfs:label>Low Risk</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="smi:MediumRisk">
        <rdfs:subClassOf rdf:resource="smi:RiskLevel"/>
        <rdfs:label>Medium Risk</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="smi:HighRisk">
        <rdfs:subClassOf rdf:resource="smi:RiskLevel"/>
        <rdfs:label>High Risk</rdfs:label>
    </owl:Class>

    <!-- Investor -->
    <owl:Class rdf:about="smi:Investor">
        <rdfs:label>Investor</rdfs:label>
        <rdfs:comment>A person or entity that places capital into financial instruments.</rdfs:comment>
    </owl:Class>
    <owl:Class rdf:about="smi:RetailInvestor">
        <rdfs:subClassOf rdf:resource="smi:Investor"/>
        <rdfs:label>Retail Investor</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="smi:InstitutionalInvestor">
        <rdfs:subClassOf rdf:resource="smi:Investor"/>
        <rdfs:label>Institutional Investor</rdfs:label>
    </owl:Class>

    <!-- Portfolio -->
    <owl:Class rdf:about="smi:Portfolio">
        <rdfs:label>Portfolio</rdfs:label>
        <rdfs:comment>A collection of financial instruments owned by an investor.</rdfs:comment>
    </owl:Class>

    <!-- InvestmentStrategy -->
    <owl:Class rdf:about="smi:InvestmentStrategy">
        <rdfs:label>Investment Strategy</rdfs:label>
        <rdfs:comment>An approach or plan for allocating capital in financial instruments.</rdfs:comment>
    </owl:Class>
    <owl:Class rdf:about="smi:AggressiveStrategy">
        <rdfs:subClassOf rdf:resource="smi:InvestmentStrategy"/>
        <rdfs:label>Aggressive Strategy</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="smi:ConservativeStrategy">
        <rdfs:subClassOf rdf:resource="smi:InvestmentStrategy"/>
        <rdfs:label>Conservative Strategy</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="smi:BalancedStrategy">
        <rdfs:subClassOf rdf:resource="smi:InvestmentStrategy"/>
        <rdfs:label>Balanced Strategy</rdfs:label>
    </owl:Class>

    <!-- Market Index -->
    <owl:Class rdf:about="smi:MarketIndex">
        <rdfs:label>Market Index</rdfs:label>
        <rdfs:comment>A benchmark tracking the performance of a group of stocks (e.g., S&amp;P 500).</rdfs:comment>
    </owl:Class>

    <!-- Transaction -->
    <owl:Class rdf:about="smi:Transaction">
        <rdfs:label>Transaction</rdfs:label>
        <rdfs:comment>A buy or sell event of a financial instrument.</rdfs:comment>
    </owl:Class>
    <owl:Class rdf:about="smi:BuyTransaction">
        <rdfs:subClassOf rdf:resource="smi:Transaction"/>
        <rdfs:label>Buy Transaction</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="smi:SellTransaction">
        <rdfs:subClassOf rdf:resource="smi:Transaction"/>
        <rdfs:label>Sell Transaction</rdfs:label>
    </owl:Class>

    <!-- ============================================================ -->
    <!--  DISJOINT CLASSES                                             -->
    <!-- ============================================================ -->

    <owl:AllDisjointClasses>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="smi:GrowthStock"/>
            <rdf:Description rdf:about="smi:ValueStock"/>
            <rdf:Description rdf:about="smi:PennyStock"/>
        </owl:members>
    </owl:AllDisjointClasses>

    <owl:AllDisjointClasses>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="smi:LowRisk"/>
            <rdf:Description rdf:about="smi:MediumRisk"/>
            <rdf:Description rdf:about="smi:HighRisk"/>
        </owl:members>
    </owl:AllDisjointClasses>

    <owl:AllDisjointClasses>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="smi:AggressiveStrategy"/>
            <rdf:Description rdf:about="smi:ConservativeStrategy"/>
            <rdf:Description rdf:about="smi:BalancedStrategy"/>
        </owl:members>
    </owl:AllDisjointClasses>

    <!-- ============================================================ -->
    <!--  OBJECT PROPERTIES                                            -->
    <!-- ============================================================ -->

    <!-- hasRiskLevel: Stock → RiskLevel -->
    <owl:ObjectProperty rdf:about="smi:hasRiskLevel">
        <rdfs:label>has Risk Level</rdfs:label>
        <rdfs:domain rdf:resource="smi:FinancialInstrument"/>
        <rdfs:range rdf:resource="smi:RiskLevel"/>
        <rdf:type rdf:resource="owl:FunctionalProperty"/>
        <rdfs:comment>Associates a financial instrument with its risk classification.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- issuedBy: Stock → Company -->
    <owl:ObjectProperty rdf:about="smi:issuedBy">
        <rdfs:label>is Issued By</rdfs:label>
        <rdfs:domain rdf:resource="smi:Stock"/>
        <rdfs:range rdf:resource="smi:Company"/>
        <rdf:type rdf:resource="owl:FunctionalProperty"/>
        <rdfs:comment>Links a stock to the company that issued it.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- issuesStock: Company → Stock (inverse of issuedBy) -->
    <owl:ObjectProperty rdf:about="smi:issuesStock">
        <rdfs:label>issues Stock</rdfs:label>
        <owl:inverseOf rdf:resource="smi:issuedBy"/>
        <rdfs:domain rdf:resource="smi:Company"/>
        <rdfs:range rdf:resource="smi:Stock"/>
    </owl:ObjectProperty>

    <!-- belongsToSector: Company → MarketSector -->
    <owl:ObjectProperty rdf:about="smi:belongsToSector">
        <rdfs:label>belongs To Sector</rdfs:label>
        <rdfs:domain rdf:resource="smi:Company"/>
        <rdfs:range rdf:resource="smi:MarketSector"/>
        <rdf:type rdf:resource="owl:FunctionalProperty"/>
    </owl:ObjectProperty>

    <!-- ownsPortfolio: Investor → Portfolio -->
    <owl:ObjectProperty rdf:about="smi:ownsPortfolio">
        <rdfs:label>owns Portfolio</rdfs:label>
        <rdfs:domain rdf:resource="smi:Investor"/>
        <rdfs:range rdf:resource="smi:Portfolio"/>
        <rdf:type rdf:resource="owl:InverseFunctionalProperty"/>
    </owl:ObjectProperty>

    <!-- containsInstrument: Portfolio → FinancialInstrument -->
    <owl:ObjectProperty rdf:about="smi:containsInstrument">
        <rdfs:label>contains Instrument</rdfs:label>
        <rdfs:domain rdf:resource="smi:Portfolio"/>
        <rdfs:range rdf:resource="smi:FinancialInstrument"/>
    </owl:ObjectProperty>

    <!-- followsStrategy: Investor → InvestmentStrategy -->
    <owl:ObjectProperty rdf:about="smi:followsStrategy">
        <rdfs:label>follows Strategy</rdfs:label>
        <rdfs:domain rdf:resource="smi:Investor"/>
        <rdfs:range rdf:resource="smi:InvestmentStrategy"/>
        <rdf:type rdf:resource="owl:FunctionalProperty"/>
    </owl:ObjectProperty>

    <!-- trackedByIndex: Stock → MarketIndex -->
    <owl:ObjectProperty rdf:about="smi:trackedByIndex">
        <rdfs:label>tracked By Index</rdfs:label>
        <rdfs:domain rdf:resource="smi:Stock"/>
        <rdfs:range rdf:resource="smi:MarketIndex"/>
    </owl:ObjectProperty>

    <!-- performedBy: Transaction → Investor -->
    <owl:ObjectProperty rdf:about="smi:performedBy">
        <rdfs:label>performed By</rdfs:label>
        <rdfs:domain rdf:resource="smi:Transaction"/>
        <rdfs:range rdf:resource="smi:Investor"/>
        <rdf:type rdf:resource="owl:FunctionalProperty"/>
    </owl:ObjectProperty>

    <!-- involvesInstrument: Transaction → FinancialInstrument -->
    <owl:ObjectProperty rdf:about="smi:involvesInstrument">
        <rdfs:label>involves Instrument</rdfs:label>
        <rdfs:domain rdf:resource="smi:Transaction"/>
        <rdfs:range rdf:resource="smi:FinancialInstrument"/>
        <rdf:type rdf:resource="owl:FunctionalProperty"/>
    </owl:ObjectProperty>

    <!-- ============================================================ -->
    <!--  DATA PROPERTIES                                              -->
    <!-- ============================================================ -->

    <!-- Stock ticker symbol -->
    <owl:DatatypeProperty rdf:about="smi:tickerSymbol">
        <rdfs:label>ticker Symbol</rdfs:label>
        <rdfs:domain rdf:resource="smi:Stock"/>
        <rdfs:range rdf:resource="xsd:string"/>
        <rdf:type rdf:resource="owl:FunctionalProperty"/>
    </owl:DatatypeProperty>

    <!-- Current price -->
    <owl:DatatypeProperty rdf:about="smi:currentPrice">
        <rdfs:label>current Price (USD)</rdfs:label>
        <rdfs:domain rdf:resource="smi:FinancialInstrument"/>
        <rdfs:range rdf:resource="xsd:decimal"/>
        <rdf:type rdf:resource="owl:FunctionalProperty"/>
    </owl:DatatypeProperty>

    <!-- Market capitalisation -->
    <owl:DatatypeProperty rdf:about="smi:marketCap">
        <rdfs:label>market Cap (USD billions)</rdfs:label>
        <rdfs:domain rdf:resource="smi:Stock"/>
        <rdfs:range rdf:resource="xsd:decimal"/>
        <rdf:type rdf:resource="owl:FunctionalProperty"/>
    </owl:DatatypeProperty>

    <!-- Annual dividend yield (percentage) -->
    <owl:DatatypeProperty rdf:about="smi:dividendYield">
        <rdfs:label>dividend Yield (%)</rdfs:label>
        <rdfs:domain rdf:resource="smi:Stock"/>
        <rdfs:range rdf:resource="xsd:decimal"/>
        <rdf:type rdf:resource="owl:FunctionalProperty"/>
    </owl:DatatypeProperty>

    <!-- Price-to-Earnings ratio -->
    <owl:DatatypeProperty rdf:about="smi:peRatio">
        <rdfs:label>P/E Ratio</rdfs:label>
        <rdfs:domain rdf:resource="smi:Stock"/>
        <rdfs:range rdf:resource="xsd:decimal"/>
        <rdf:type rdf:resource="owl:FunctionalProperty"/>
    </owl:DatatypeProperty>

    <!-- Beta (volatility relative to market) -->
    <owl:DatatypeProperty rdf:about="smi:beta">
        <rdfs:label>Beta</rdfs:label>
        <rdfs:domain rdf:resource="smi:Stock"/>
        <rdfs:range rdf:resource="xsd:decimal"/>
        <rdf:type rdf:resource="owl:FunctionalProperty"/>
    </owl:DatatypeProperty>

    <!-- 52-week high -->
    <owl:DatatypeProperty rdf:about="smi:fiftyTwoWeekHigh">
        <rdfs:label>52-Week High (USD)</rdfs:label>
        <rdfs:domain rdf:resource="smi:Stock"/>
        <rdfs:range rdf:resource="xsd:decimal"/>
    </owl:DatatypeProperty>

    <!-- 52-week low -->
    <owl:DatatypeProperty rdf:about="smi:fiftyTwoWeekLow">
        <rdfs:label>52-Week Low (USD)</rdfs:label>
        <rdfs:domain rdf:resource="smi:Stock"/>
        <rdfs:range rdf:resource="xsd:decimal"/>
    </owl:DatatypeProperty>

    <!-- Company name -->
    <owl:DatatypeProperty rdf:about="smi:companyName">
        <rdfs:label>company Name</rdfs:label>
        <rdfs:domain rdf:resource="smi:Company"/>
        <rdfs:range rdf:resource="xsd:string"/>
        <rdf:type rdf:resource="owl:FunctionalProperty"/>
    </owl:DatatypeProperty>

    <!-- Country of origin -->
    <owl:DatatypeProperty rdf:about="smi:country">
        <rdfs:label>country</rdfs:label>
        <rdfs:domain rdf:resource="smi:Company"/>
        <rdfs:range rdf:resource="xsd:string"/>
    </owl:DatatypeProperty>

    <!-- Investor name -->
    <owl:DatatypeProperty rdf:about="smi:investorName">
        <rdfs:label>investor Name</rdfs:label>
        <rdfs:domain rdf:resource="smi:Investor"/>
        <rdfs:range rdf:resource="xsd:string"/>
        <rdf:type rdf:resource="owl:FunctionalProperty"/>
    </owl:DatatypeProperty>

    <!-- Portfolio total value -->
    <owl:DatatypeProperty rdf:about="smi:portfolioValue">
        <rdfs:label>portfolio Value (USD)</rdfs:label>
        <rdfs:domain rdf:resource="smi:Portfolio"/>
        <rdfs:range rdf:resource="xsd:decimal"/>
        <rdf:type rdf:resource="owl:FunctionalProperty"/>
    </owl:DatatypeProperty>

    <!-- Annual return (%) -->
    <owl:DatatypeProperty rdf:about="smi:annualReturn">
        <rdfs:label>annual Return (%)</rdfs:label>
        <rdfs:domain rdf:resource="smi:Portfolio"/>
        <rdfs:range rdf:resource="xsd:decimal"/>
    </owl:DatatypeProperty>

    <!-- Transaction date -->
    <owl:DatatypeProperty rdf:about="smi:transactionDate">
        <rdfs:label>transaction Date</rdfs:label>
        <rdfs:domain rdf:resource="smi:Transaction"/>
        <rdfs:range rdf:resource="xsd:date"/>
        <rdf:type rdf:resource="owl:FunctionalProperty"/>
    </owl:DatatypeProperty>

    <!-- Transaction quantity -->
    <owl:DatatypeProperty rdf:about="smi:quantity">
        <rdfs:label>quantity (shares)</rdfs:label>
        <rdfs:domain rdf:resource="smi:Transaction"/>
        <rdfs:range rdf:resource="xsd:integer"/>
        <rdf:type rdf:resource="owl:FunctionalProperty"/>
    </owl:DatatypeProperty>

    <!-- Transaction price per share -->
    <owl:DatatypeProperty rdf:about="smi:pricePerShare">
        <rdfs:label>price Per Share (USD)</rdfs:label>
        <rdfs:domain rdf:resource="smi:Transaction"/>
        <rdfs:range rdf:resource="xsd:decimal"/>
        <rdf:type rdf:resource="owl:FunctionalProperty"/>
    </owl:DatatypeProperty>

    <!-- Index name -->
    <owl:DatatypeProperty rdf:about="smi:indexName">
        <rdfs:label>index Name</rdfs:label>
        <rdfs:domain rdf:resource="smi:MarketIndex"/>
        <rdfs:range rdf:resource="xsd:string"/>
        <rdf:type rdf:resource="owl:FunctionalProperty"/>
    </owl:DatatypeProperty>

    <!-- ============================================================ -->
    <!--  OWL RESTRICTIONS ON CLASSES                                  -->
    <!-- ============================================================ -->

    <!-- DividendStock must have dividendYield > 0 (modelled as hasValue restriction) -->
    <owl:Class rdf:about="smi:DividendStock">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="smi:hasRiskLevel"/>
                <owl:someValuesFrom rdf:resource="smi:RiskLevel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- Every Portfolio must containsInstrument at least 1 FinancialInstrument -->
    <owl:Class rdf:about="smi:Portfolio">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="smi:containsInstrument"/>
                <owl:minCardinality rdf:datatype="xsd:nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- Every Stock must be issuedBy exactly 1 Company -->
    <owl:Class rdf:about="smi:Stock">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="smi:issuedBy"/>
                <owl:cardinality rdf:datatype="xsd:nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="smi:hasRiskLevel"/>
                <owl:cardinality rdf:datatype="xsd:nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- ============================================================ -->
    <!--  INDIVIDUALS — Market Sectors                                 -->
    <!-- ============================================================ -->

    <smi:TechnologySector rdf:about="smi:Tech">
        <rdfs:label>Technology</rdfs:label>
    </smi:TechnologySector>

    <smi:HealthcareSector rdf:about="smi:Healthcare">
        <rdfs:label>Healthcare</rdfs:label>
    </smi:HealthcareSector>

    <smi:EnergySector rdf:about="smi:Energy">
        <rdfs:label>Energy</rdfs:label>
    </smi:EnergySector>

    <smi:FinancialSector rdf:about="smi:Finance">
        <rdfs:label>Finance</rdfs:label>
    </smi:FinancialSector>

    <smi:ConsumerGoodsSector rdf:about="smi:ConsumerGoods">
        <rdfs:label>Consumer Goods</rdfs:label>
    </smi:ConsumerGoodsSector>

    <!-- ============================================================ -->
    <!--  INDIVIDUALS — Risk Levels                                    -->
    <!-- ============================================================ -->

    <smi:LowRisk rdf:about="smi:LowRiskLevel">
        <rdfs:label>Low Risk</rdfs:label>
    </smi:LowRisk>

    <smi:MediumRisk rdf:about="smi:MediumRiskLevel">
        <rdfs:label>Medium Risk</rdfs:label>
    </smi:MediumRisk>

    <smi:HighRisk rdf:about="smi:HighRiskLevel">
        <rdfs:label>High Risk</rdfs:label>
    </smi:HighRisk>

    <!-- ============================================================ -->
    <!--  INDIVIDUALS — Market Indices                                 -->
    <!-- ============================================================ -->

    <smi:MarketIndex rdf:about="smi:SP500">
        <smi:indexName>S&amp;P 500</smi:indexName>
        <rdfs:label>S&amp;P 500</rdfs:label>
    </smi:MarketIndex>

    <smi:MarketIndex rdf:about="smi:NASDAQ">
        <smi:indexName>NASDAQ Composite</smi:indexName>
        <rdfs:label>NASDAQ</rdfs:label>
    </smi:MarketIndex>

    <smi:MarketIndex rdf:about="smi:DowJones">
        <smi:indexName>Dow Jones Industrial Average</smi:indexName>
        <rdfs:label>Dow Jones</rdfs:label>
    </smi:MarketIndex>

    <!-- ============================================================ -->
    <!--  INDIVIDUALS — Companies                                      -->
    <!-- ============================================================ -->

    <smi:Company rdf:about="smi:Apple_Inc">
        <smi:companyName>Apple Inc.</smi:companyName>
        <smi:country>USA</smi:country>
        <smi:belongsToSector rdf:resource="smi:Tech"/>
        <rdfs:label>Apple Inc.</rdfs:label>
    </smi:Company>

    <smi:Company rdf:about="smi:Microsoft_Corp">
        <smi:companyName>Microsoft Corporation</smi:companyName>
        <smi:country>USA</smi:country>
        <smi:belongsToSector rdf:resource="smi:Tech"/>
        <rdfs:label>Microsoft Corporation</rdfs:label>
    </smi:Company>

    <smi:Company rdf:about="smi:Tesla_Inc">
        <smi:companyName>Tesla Inc.</smi:companyName>
        <smi:country>USA</smi:country>
        <smi:belongsToSector rdf:resource="smi:Tech"/>
        <rdfs:label>Tesla Inc.</rdfs:label>
    </smi:Company>

    <smi:Company rdf:about="smi:Johnson_Johnson">
        <smi:companyName>Johnson &amp; Johnson</smi:companyName>
        <smi:country>USA</smi:country>
        <smi:belongsToSector rdf:resource="smi:Healthcare"/>
        <rdfs:label>Johnson &amp; Johnson</rdfs:label>
    </smi:Company>

    <smi:Company rdf:about="smi:Pfizer">
        <smi:companyName>Pfizer Inc.</smi:companyName>
        <smi:country>USA</smi:country>
        <smi:belongsToSector rdf:resource="smi:Healthcare"/>
        <rdfs:label>Pfizer Inc.</rdfs:label>
    </smi:Company>

    <smi:Company rdf:about="smi:ExxonMobil">
